#. The preferences menu item shown in the GNOME input menu.
msgid "Preferences"
msgstr "Tùy chỉnh"

msgid "Bambusa Preferences"
msgstr "Tùy chỉnh Bambusa"

msgid "Main menu"
msgstr "Menu chính"

msgid "Help"
msgstr "Trợ giúp"

msgid "About"
msgstr "Giới thiệu"

msgid "A Vietnamese input method for GNOME."
msgstr "Bộ gõ tiếng Việt cho GNOME."

msgid "Coded by"
msgstr "Lập trình bởi"

msgid "Based on ibus-bamboo by"
msgstr "Dựa trên ibus-bamboo của"

msgid "Dictionary by"
msgstr "Từ điển bởi"

msgid "Output"
msgstr "Đầu ra"

msgid "Character set"
msgstr "Bộ ký tự"

msgid "Composed Unicode"
msgstr "Unicode tổ hợp"

msgid "Input"
msgstr "Đầu vào"

msgid "Input mode"
msgstr "Chế độ nhập"

msgid "Preedit"
msgstr "Soạn thảo trước"

msgid "Surrounding text"
msgstr "Văn bản xung quanh"

msgid "Tone marking"
msgstr "Đánh dấu thanh"

msgid "Free tone marking"
msgstr "Đánh dấu thanh tự do"

msgid "Accept tone marks anywhere in the word, not only after the vowel."
msgstr "Chấp nhận dấu thanh ở bất kỳ đâu trong từ, không chỉ sau nguyên âm."

msgid "Modern tone placement"
msgstr "Đặt dấu thanh kiểu mới"

msgid "Place the tone on the second vowel in cases like “oa”, “uy” (hoà, not hòa)."
msgstr "Đặt dấu thanh trên nguyên âm thứ hai trong các trường hợp như “oa”, “uy” (hoà, không phải hòa)."

msgid "Spell checking"
msgstr "Kiểm tra chính tả"

msgid "Check spelling"
msgstr "Bật kiểm tra chính tả"

msgid "Fall back to the raw keystrokes when a word is not valid Vietnamese."
msgstr "Trở về các phím gõ thô khi từ không phải tiếng Việt hợp lệ."

msgid "Use spelling rules"
msgstr "Dùng quy tắc chính tả"

msgid "Accept syllables that follow Vietnamese spelling rules."
msgstr "Chấp nhận các âm tiết theo quy tắc chính tả tiếng Việt."

msgid "Use dictionary"
msgstr "Dùng từ điển"

msgid "Also accept whole words found in the bundled dictionary."
msgstr "Cũng chấp nhận các từ có trong từ điển đi kèm."

msgid "Behaviour"
msgstr "Hành vi"

msgid "Restore non-Vietnamese words"
msgstr "Khôi phục từ không phải tiếng Việt"

msgid "Undo composition automatically for words that are not Vietnamese."
msgstr "Tự động hoàn tác khi từ không phải tiếng Việt."

msgid "Hide preedit underline"
msgstr "Ẩn gạch chân khi soạn thảo"

msgid "Macros"
msgstr "Macro"

msgid "Enable macros"
msgstr "Bật macro"

msgid "Expand a shortcut to its full text on Space or Tab."
msgstr "Mở rộng chữ viết tắt thành văn bản đầy đủ khi nhấn Space hoặc Tab."

msgid "Auto-capitalize macros"
msgstr "Tự động viết hoa macro"

msgid "Match the expansion's case to how you type the shortcut."
msgstr "Khớp kiểu chữ hoa/thường của đoạn thay thế với cách bạn gõ chữ viết tắt."

msgid "Edit macros"
msgstr "Sửa macro"

msgid "Import macros"
msgstr "Nhập macro"

msgid "Export macros"
msgstr "Xuất macro"

msgid "Remove"
msgstr "Xoá"

msgid "Cancel"
msgstr "Huỷ"

msgid "Add"
msgstr "Thêm"

msgid "Shortcut"
msgstr "Chữ viết tắt"

msgid "Expansion"
msgstr "Đoạn thay thế"
